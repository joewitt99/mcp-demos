# Copy to .env for local dev. Render reads these from the service env, not this file.

# ---- HTTP transport ----
HOST=0.0.0.0
PORT=8000

# ---- MCP list pagination ----
# Page size for tools/resources/prompts list operations. Defaults to 30.
MCP_LIST_PAGE_SIZE=30

# ---- Okta access-token verification ----
# Full issuer URL of your Okta custom authorization server.
OKTA_ISSUER=https://dev-123456.okta.com/oauth2/default

# Audience value configured on the custom auth server (e.g. api://default).
OKTA_AUDIENCE=api://default

# Optional: lock the server to a specific Okta application (checks `cid` claim).
# OKTA_CLIENT_ID=0oa1bcdEFG...

# Optional override; defaults to {OKTA_ISSUER}/v1/keys.
# OKTA_JWKS_URI=

# Optional: comma-separated scopes the access token must include.
# OKTA_REQUIRED_SCOPES=mcp.read,mcp.write

# Optional informational value (not used for validation).
# OKTA_DOMAIN=dev-123456.okta.com

# Optional public URL of this MCP server (RFC 8707 resource indicator).
# MCP_BASE_URL=https://swiss-army-mcp.onrender.com

# Set to "true" to bypass Okta verification entirely (LOCAL DEV ONLY).
# MCP_AUTH_DISABLED=false
