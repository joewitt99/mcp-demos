# Copy to vars.env and fill in. Do NOT commit vars.env — it's git-ignored.

# ---- AWS target ----
# Region for ALL resources. Cert ARN must live in this region too.
AWS_REGION="us-east-1"

# Name used for ECR repo, ECS service, task family, target group, log group.
SERVICE_NAME="swiss-army-mcp"

# Public hostname for this demo (must be under your delegated zone).
HOSTNAME="swiss-army-mcp.bridge.oktaproserv.com"

# Wildcard ACM cert covering HOSTNAME, in AWS_REGION.
# Find: aws acm list-certificates --region us-east-1
CERT_ARN="arn:aws:acm:us-east-1:<account>:certificate/<id>"

# Route 53 hosted zone ID for the delegated zone (e.g. bridge.oktaproserv.com).
# Find: aws route53 list-hosted-zones-by-name --dns-name bridge.oktaproserv.com
HOSTED_ZONE_ID="Z..."

# ---- VPC (existing) ----
# Find: aws ec2 describe-vpcs --region "$AWS_REGION"
VPC_ID="vpc-..."

# ALB subnets: 2+ PUBLIC subnets in different AZs (comma-separated, no spaces).
# Find: aws ec2 describe-subnets --filters "Name=vpc-id,Values=$VPC_ID" \
#         --query 'Subnets[?MapPublicIpOnLaunch==`true`].[SubnetId,AvailabilityZone]' \
#         --region "$AWS_REGION" --output table
PUBLIC_SUBNET_IDS="subnet-aaa,subnet-bbb"

# Task subnets: where Fargate tasks run. Two options:
#   (a) Private subnets with a NAT route (preferred, more secure).
#   (b) The PUBLIC_SUBNET_IDS above with ASSIGN_PUBLIC_IP=ENABLED (cheaper — no NAT).
TASK_SUBNET_IDS="subnet-aaa,subnet-bbb"
ASSIGN_PUBLIC_IP="ENABLED"   # ENABLED for option (b), DISABLED for option (a)

# ---- ECS sizing ----
CLUSTER_NAME="mcp-demos"
TASK_CPU="256"        # 0.25 vCPU
TASK_MEMORY="512"     # 512 MB
DESIRED_COUNT="1"     # safe to raise — server runs in stateless_http mode
CONTAINER_PORT="8000"

# ---- Application config (passed to the container as env vars) ----
MCP_LIST_PAGE_SIZE="30"

# Okta custom auth server values. ISSUER + AUDIENCE are required.
OKTA_ISSUER="https://<your-domain>.okta.com/oauth2/<auth-server-id>"
OKTA_AUDIENCE="api://default"
OKTA_CLIENT_IDS=""             # optional: comma-separated allow-list of Okta apps
OKTA_DOMAIN=""                 # optional, informational
OKTA_REQUIRED_SCOPES=""        # optional: comma-separated
