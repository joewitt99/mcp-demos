# Copy to terraform.tfvars and fill in. One shared instance, not per-customer.

aws_region = "us-east-1"

# ---- DNS + TLS (existing) ----
hostname       = "swiss-army-mcp.bridge.oktaproserv.com"
cert_arn       = "arn:aws:acm:us-east-1:<account>:certificate/<id>"
hosted_zone_id = "Z..."

# ---- VPC ----
# Option A: let Terraform create a minimal demo VPC (1 VPC, IGW, 2 public
# subnets in different AZs). Tasks run in the public subnets with public IPs;
# no NAT, no extra cost. Comment out vpc_id / *_subnet_ids below in this mode.
#
# create_vpc          = true
# new_vpc_cidr        = "10.42.0.0/16"
# availability_zones  = ["us-east-1a", "us-east-1b"]   # required if your role denies ec2:DescribeAvailabilityZones

# Option B: bring your own VPC. Required when create_vpc = false (default).
vpc_id            = "vpc-..."
public_subnet_ids = ["subnet-aaa", "subnet-bbb"]
task_subnet_ids   = ["subnet-aaa", "subnet-bbb"]
assign_public_ip  = true   # true when task_subnet_ids are public (no NAT)

# ---- Image ----
image_tag = "0.5.3"

# ---- SSM tenants prefix (default is fine for most setups) ----
# tenants_prefix = "/swiss-army-mcp/tenants/"
